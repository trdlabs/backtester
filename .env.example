BACKTESTER_QUEUE_RETRY_AFTER_S=30

# Дефолтный таймаут ожидания в очереди (6 ч).
BACKTESTER_QUEUE_TIMEOUT_MS=21600000

# Bearer-токен живой real-platform; обязателен при BACKTESTER_DATA_SOURCE=real (fail-fast).
