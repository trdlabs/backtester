# Стабильный id worker-процесса (владелец lease); дефолт вычисляется: hostname:pid.
# WORKER_ID=

# Lease TTL при claim (клампится к >= 3 * heartbeat; см. P3-5 guidance в config.ts).
WORKER_LEASE_TTL_MS=30000

# Максимум claim-попыток до пометки повторно-осиротевшего job как poison.
WORKER_MAX_ATTEMPTS=3

# Интервал idle-опроса пустой очереди (клампится к >= 50).
WORKER_POLL_MS=500
