# flag [off|enforce], default_state: off
# BACKTESTER_HOLDOUT_ENABLED=

# E4a: held-out окно = последняя доля coverage; читается только при BACKTESTER_HOLDOUT_ENABLED. Fail-fast при включённом holdout: конечное число в (0,1).
BACKTESTER_HOLDOUT_FRACTION=0.2

# Bind-адрес HTTP API. Не-loopback требует явный BACKTESTER_AUTH_TOKEN (fail-fast, P2-10).
BACKTESTER_HOST=127.0.0.1

# true = аккумулировать per-session IPC-профиль (open/wait тайминги), дамп на close(). Читается один раз при инициализации класса SandboxSession.
BACKTESTER_IPC_PROFILE=false

# Per-job observability: терминальная лог-строка + /statsz.
