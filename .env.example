BACKTESTER_RUN_TIMEOUT_MS=7200000

# S3 access key; обязателен при BACKTESTER_STORE_BACKEND=s3 (fail-fast).
# secret — значение в SOPS/age-контуре, см. b2c-ops-hardening item 3
