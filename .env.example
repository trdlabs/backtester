# bench-workers: режим бенча (незнакомое значение НЕ валидируется — приводится as-cast).
BENCH_MODE=momentum

# Bench: число submit; дефолт зависит от потребителя (6 в bench-parallel-drain, клампится к >= 2; 120/12 по режиму в bench-workers).
