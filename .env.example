# produce-long-oi-evidence: путь к snapshot-файлу датасета.
# LONGOI_SNAPSHOT=

# Путь к чекауту trading-platform для cross-repo/evidence/golden-sync тестов; дефолт вычисляется (локальный путь разработчика), без чекаута тесты скипаются.
# PLATFORM_REPO=

# validate-execution: допуск сверки PnL с эталоном.
PNL_TOL=0.0001

# Значение 1 включает bench-parallel-drain (иначе skip).
# RUN_BENCH=

# true включает opt-in cross-repo historical E2E (детерминизм-гейт против реального platform-чекаута).
RUN_CROSS_REPO_E2E=false

# Скрипты фикстур/валидации: путь к slice-файлу исторических данных; дефолт вычисляется per-скрипт.
# SLICE_PATH=

# Ёмкость LRU tape-кэша воркера; 0 = выключить кэш; мусор → 16. Читается при создании синглтонов.
TAPE_CACHE_MAX_ENTRIES=16

# Максимум одновременных backtest-ранов in-process worker-пула (клампится к >= 1; 1 = serial).
WORKER_CONCURRENCY=4

# P2-7: первый бэккофф после ошибки итерации worker-loop (клампится к >= 50; удваивается).
WORKER_ERROR_BACKOFF_BASE_MS=500

# P2-7: потолок бэккоффа worker-loop (клампится к >= base).
WORKER_ERROR_BACKOFF_MAX_MS=30000

# TCP-порт health-сервера воркера (/healthz + /readyz); не задан = сервер не поднимается.
# WORKER_HEALTH_PORT=

# Интервал heartbeat: воркеры продлевают in-flight lease (клампится к >= 1000).
