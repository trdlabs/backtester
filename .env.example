# Корень content-addressed стора артефактов; дефолт вычисляется: apps/backtester/.data/artifacts.
# BACKTESTER_ARTIFACTS_DIR=

# Bearer-токен /v1 API (fail-closed). На loopback допустим dev-дефолт; на не-loopback BACKTESTER_HOST обязателен (fail-fast, P2-10).
# secret — значение в SOPS/age-контуре, см. b2c-ops-hardening item 3
BACKTESTER_AUTH_TOKEN=

# HTTP-нода запускает фоновый worker-tick; false — только API (multi-process с worker-main).
BACKTESTER_AUTO_WORKER=true

# 17b: батчинг flat-stretch onBarClose в одно sandbox-сообщение (dark launch). Взаимоисключим с BACKTESTER_BAR_MAJOR (fail-fast).
# flag [off|enforce], default_state: off
# BACKTESTER_BAR_BATCHING=

# 17d: bar-major исполнение — один бар по всем символам до продвижения (dark launch). Взаимоисключим с BACKTESTER_BAR_BATCHING (fail-fast).
# flag [off|enforce], default_state: off
# BACKTESTER_BAR_MAJOR=

# Slice B: 3-фазный батч-транспорт per-bar IPC bar-major; чистый суб-режим BACKTESTER_BAR_MAJOR (инертен без него).
# flag [off|enforce], default_state: off
# BACKTESTER_BAR_MAJOR_BATCH=

# 17b: максимум баров на hookBatch (клампится к >= 2; мусор → 64).
BACKTESTER_BATCH_BARS=64

# Корень content-addressed реестра модулей-бандлов; дефолт вычисляется: apps/backtester/.data/bundles.
# BACKTESTER_BUNDLES_DIR=

# In-flight коалесцирование запросов (leader/follower); эффективен только вместе с BACKTESTER_DEDUP_ENABLED.
# flag [off|enforce], default_state: off
# BACKTESTER_COALESCE_ENABLED=

# TTL compute-lock (мс); дефолт вычисляется = workerLeaseTtlMs.
# BACKTESTER_COMPUTE_LOCK_TTL_MS=

# Poison-cap попыток compute_wait.
BACKTESTER_COMPUTE_WAIT_MAX_ATTEMPTS=3

# P2-12: всего попыток на data-API запрос, включая первую (1 = без ретраев). Fail-fast: конечное число >= 1.
BACKTESTER_DATA_API_MAX_ATTEMPTS=3

# P2-12: fail-closed cap страниц одного queryRange. Fail-fast: конечное число >= 1.
BACKTESTER_DATA_API_MAX_PAGES=10000

# P2-12: fail-closed cap строк одного queryRange (защита materialize). Fail-fast: конечное число >= 1.
BACKTESTER_DATA_API_MAX_ROWS=5000000

# P2-12: дедлайн всего queryRange через страницы+ретраи; 0 = выключен. Fail-fast: конечное число >= 0.
BACKTESTER_DATA_API_OPERATION_DEADLINE_MS=0

# Лимит строк на страницу data-API.
BACKTESTER_DATA_API_PAGE_LIMIT=1000

# P2-12: базовая задержка ретрая (full jitter, удвоение). Fail-fast: конечное число >= 1.
BACKTESTER_DATA_API_RETRY_BASE_MS=500

# P2-12: потолок бэккоффа ретрая; fail-fast: >= BACKTESTER_DATA_API_RETRY_BASE_MS.
BACKTESTER_DATA_API_RETRY_MAX_MS=10000

# P2-12: per-request таймаут HttpDataPort. Fail-fast: конечное число >= 1.
BACKTESTER_DATA_API_TIMEOUT_MS=30000

# Bearer-токен Research Historical Data API (НЕ биржевые креды).
# secret — значение в SOPS/age-контуре, см. b2c-ops-hardening item 3
BACKTESTER_DATA_API_TOKEN=

# Базовый URL Research Historical Data API; требуется при BACKTESTER_DATA_SOURCE=http.
# BACKTESTER_DATA_API_URL=

# Источник исторических данных: fixture (in-process), http (data-API), mock/real (rows-порт /historical/rows). Незнакомое значение тихо резолвится в fixture; real требует BACKTESTER_REAL_PLATFORM_URL/_TOKEN (fail-fast).
BACKTESTER_DATA_SOURCE=fixture

# Fingerprint-based result-dedup кэш (dark launch).
# flag [off|enforce], default_state: off
# BACKTESTER_DEDUP_ENABLED=

# E1b: порог флага single_trade_dominated (% гросс-прибыли); 0 = максимальная чувствительность.
BACKTESTER_DIAG_CONCENTRATION_PCT=80

# E1b: порог флага underpowered (трейдов); 0 = отключить флаг.
BACKTESTER_DIAG_MIN_TRADES=30

# Lifted overlay-путь движка (engine:overlay); OFF до зелёного verify_018 parity-гейта.
