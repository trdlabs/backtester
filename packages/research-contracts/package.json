{
  "name": "@trading/research-contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared research/backtest contract types (017/022) and the historical data port. Parity anchor — consumed by trading-backtester and (future) trading-lab. Not published to npm.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./research": {
      "types": "./src/research/index.ts",
      "default": "./src/research/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "dependencies": {
    "@trading-backtester/sdk": "workspace:*",
    "@trading-platform/sdk": "https://github.com/alexnikolskiy/trading-platform-sdk/releases/download/sdk-v0.4.0/trading-platform-sdk-0.4.0.tgz"
  }
}
