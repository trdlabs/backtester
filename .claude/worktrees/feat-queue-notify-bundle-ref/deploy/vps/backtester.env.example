# Recommended single-user working-env config for the backtester (API + worker).
# Copy to `backtester.env` (gitignored), fill secrets, then `./up.sh`.
#
# The three perf flags below are ENABLED here on purpose: dedup + in-flight
# coalescing were validated PASS on a controlled small sweep (ROADMAP item 11a)
# and are the recommended single-user posture. All three default to OFF in code
# (dark-launch); enabling them is an operational choice, not a code default flip.

# --- shared / secrets ---------------------------------------------------------
DATABASE_URL=postgres://backtester:backtester@127.0.0.1:15433/backtester
BACKTESTER_AUTH_TOKEN=CHANGE_ME
BACKTESTER_HOST=127.0.0.1
BACKTESTER_PORT=18080

# --- historical data (mock-platform on this box) ------------------------------
BACKTESTER_DATA_SOURCE=mock
BACKTESTER_MOCK_PLATFORM_URL=http://127.0.0.1:8890
BACKTESTER_MOCK_PLATFORM_TOKEN=CHANGE_ME

# --- content stores -----------------------------------------------------------
BACKTESTER_ARTIFACTS_DIR=/root/bt-data/artifacts
BACKTESTER_BUNDLES_DIR=/root/bt-data/bundles

# --- perf posture (ENABLED — the point of this config) ------------------------
BACKTESTER_DEDUP_ENABLED=true
BACKTESTER_COALESCE_ENABLED=true
BACKTESTER_JOB_OBS=true

# --- backpressure / connection hardening (Tier 2 lite; safe defaults) ---------
BACKTESTER_PG_POOL_MAX=10
BACKTESTER_PG_STATEMENT_TIMEOUT_MS=30000

# --- worker shape -------------------------------------------------------------
# WORKER_CONCURRENCY=2 lets in-flight coalescing engage in one process (a follower
# claims while the leader computes). Scaling out later? prefer process-per-slot
# (concurrency=1 × N workers) — strategy runs do NOT overlap in one JS thread.
WORKER_CONCURRENCY=2
WORKER_HEALTH_PORT=18081

# Bar batching stays OFF — VPS A/B (2026-07-04) measured it ~2.2x SLOWER on
# signal-dense strategies like long_oi (see ROADMAP 17b). Do not enable without
# a per-strategy A/B showing a hookCall collapse.
BACKTESTER_BAR_BATCHING=false
