{
  "name": "trading-backtester",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "check": "pnpm typecheck && pnpm test",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:sandbox-harness-overlay": "node apps/backtester/scripts/build-sandbox-harness-overlay.mjs",
    "sdk:build": "pnpm --filter @trdlabs/backtester-sdk build",
    "sdk:pack": "mkdir -p .artifacts/sdk && pnpm --filter @trdlabs/backtester-sdk pack --pack-destination $PWD/.artifacts/sdk",
    "sdk:verify": "tsx scripts/verify-sdk-package.ts \".artifacts/sdk/trdlabs-backtester-sdk-$(node -p \"require('./packages/sdk/package.json').version\").tgz\"",
    "pretypecheck": "pnpm sdk:build",
    "pretest": "pnpm sdk:build && pnpm run build:sandbox-harness-overlay",
    "test": "vitest run",
    "test:watch": "vitest",
    "env:schema": "tsx scripts/print-env-schema.ts",
    "env:docs": "tsx scripts/gen-env-docs.ts",
    "env:advisory": "node scripts/env-advisory.mjs",
    "dev": "tsx watch apps/backtester/src/index.ts",
    "start": "tsx apps/backtester/src/index.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
